# 環境変数・APIキー
.env

# macOS
.DS_Store
**/.DS_Store

# Claude IDE設定
.claude/

# 中間ファイル（再生成可能な大きなバイナリ）
work/

# 最終出力動画
output/

# ソース素材（大容量バイナリ）
# ディレクトリ自体は管理し、中のファイルのみ無視
original-movies/**/*
!original-movies/.gitkeep
source-movies/**/*
!source-movies/.gitkeep
source-pdf/**/*
!source-pdf/.gitkeep

# 生成物（スクリプトで再生成可能）
source-transcriptions/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
